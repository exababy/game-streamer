# Copy to src/.env and fill in. Loaded automatically by game-streamer.sh.

# --- flow 1: setup-steam ---------------------------------------------------
export STEAM_USER=cs2_servers
export STEAM_PASSWORD=

# --- flow 2: run-live ------------------------------------------------------
export MATCH_ID=

# Pick ONE of these two pairs:
# export PLAYCAST_URL=
# - or -
export CONNECT_ADDR=
export CONNECT_PASSWORD=

# --- optional overrides ----------------------------------------------------
# export DEBUG_STREAM_ID=debug
# export FPS=30
# export VIDEO_KBPS=6000
# export STEAM_LIBRARY=/mnt/game-streamer
# export CS2_DIR="$STEAM_LIBRARY/steamapps/common/Counter-Strike Global Offensive"
# export MEDIAMTX_SRT_BASE=srt://mediamtx.5stack.svc.cluster.local:8890

# --- Vulkan shader pre-caching ---------------------------------------------
# Shaders always compile on launch so the persistent GLCache warms (first
# cold compile per GPU/driver is slow, later launches reuse it). Operators
# skip a compile per-match from the UI.
# export GL_SHADER_CACHE_DIR=/mnt/game-streamer/nvcache  # GLCache location
# export __GL_SHADER_DISK_CACHE_SIZE=10737418240         # 10 GiB cap
#
# DEBUG_STREAM=1 captures from boot (before Steam) so a boot hang is
# watchable via the "WATCH (HLS)" URL in the logs.
# export DEBUG_STREAM=1
# export DEBUG_STREAM_ID=debug      # publish path (default: MATCH_ID)
