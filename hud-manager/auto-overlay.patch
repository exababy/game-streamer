+// HTTP-driven overlay open. Mirrors the IPC `open-hud` event from the
+// admin renderer so external callers (curl, game-streamer's run-live
+// flow) can trigger the spectator HUD without going through Electron
+// IPC. openOverlayForHud is idempotent: if an overlay window is
+// already alive it reuses it via webContents.loadURL (no flash, no
+// rebuild); otherwise it creates one. This makes the call useful as
+// both a "first-time open" and a "refresh / swap variant in place".
+//
+// Body (optional): { "hudId": "<id>", "variant": "<name>" }.
+// `hudId` defaults to "default" (the bundled HUD under
+// resources/default-hud/). `variant` is appended as `?variant=<name>`
+// — JTs Hud's `default` bundle declares variants in its hud.json
+// (default | horizontal | vertical) and the bundled HUD JS reads the
+// query param at page-load to switch layout. This mirrors what the
+// admin renderer does in HudCard.vue's buildUrl()/launchHud().
+app.post('/api/overlay/start', (req, res) => {
+  try {
+    const body = req.body || {}
+    const hudId =
+      (typeof body.hudId === 'string' && body.hudId) || 'default'
+    const variant =
+      typeof body.variant === 'string' && body.variant ? body.variant : null
+    const port = process.env.HUD_PORT || 1349
+    let hudUrl = `http://localhost:${port}/huds/${hudId}/index.html`
+    if (variant) hudUrl += `?variant=${encodeURIComponent(variant)}`
+    openOverlayForHud(hudUrl)
+    res.json({ ok: true, hudId, variant, hudUrl })
+  } catch (e) {
+    res.status(500).json({ error: String(e) })
+  }
+})
